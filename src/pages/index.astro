---
import '../styles/global.css';
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>15 de Fio ✨</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;900&family=Raleway:wght@300;400;600&display=swap" rel="stylesheet" />
</head>
<body>

  <!-- Partículas de fondo -->
  <div class="particles" id="particles"></div>

  <!-- ===== HERO ===== -->
  <section class="hero">
    <div class="hex-grid-bg"></div>
    <div class="hero-content">
      <div class="rune-circle"></div>
      <p class="hero-sub">Bienvenida a la celebración de</p>
      <h1 class="hero-title">
        <span class="glow-text">Fio</span>
      </h1>
      <div class="fifteen-badge">XV</div>
      <p class="hero-desc">Quince años de magia, luz y aventura</p>
      <div class="hero-divider">
        <span></span><span class="diamond">◆</span><span></span>
      </div>
      <p class="event-date">16 · Mayo · 2026</p>
    </div>
    <div class="scroll-hint">
      <span>Desplázate</span>
      <div class="scroll-arrow"></div>
    </div>
  </section>

  <!-- ===== CONTADOR ===== -->
  <section class="section" id="countdown-section">
    <h2 class="section-title">El gran momento llega en</h2>
    <div class="countdown-grid">
      <div class="countdown-card">
        <span class="count-num" id="days">00</span>
        <span class="count-label">Días</span>
      </div>
      <div class="count-sep">:</div>
      <div class="countdown-card">
        <span class="count-num" id="hours">00</span>
        <span class="count-label">Horas</span>
      </div>
      <div class="count-sep">:</div>
      <div class="countdown-card">
        <span class="count-num" id="minutes">00</span>
        <span class="count-label">Minutos</span>
      </div>
      <div class="count-sep">:</div>
      <div class="countdown-card">
        <span class="count-num" id="seconds">00</span>
        <span class="count-label">Segundos</span>
      </div>
    </div>
  </section>

  <!-- ===== GALERÍA ===== -->
  <section class="section" id="gallery-section">
    <h2 class="section-title">Momentos que brillan</h2>
    <div class="gallery-grid">
      <div class="photo-card" style="--hue: 260deg">
        <div class="photo-inner">
          <div class="photo-placeholder">
            <span class="photo-icon">✦</span>
            <p>Foto 1</p>
          </div>
          <div class="photo-shine"></div>
        </div>
      </div>
      <div class="photo-card featured" style="--hue: 200deg">
        <div class="photo-inner">
          <div class="photo-placeholder">
            <span class="photo-icon">✦</span>
            <p>Foto principal</p>
          </div>
          <div class="photo-shine"></div>
        </div>
      </div>
      <div class="photo-card" style="--hue: 300deg">
        <div class="photo-inner">
          <div class="photo-placeholder">
            <span class="photo-icon">✦</span>
            <p>Foto 3</p>
          </div>
          <div class="photo-shine"></div>
        </div>
      </div>
      <div class="photo-card" style="--hue: 180deg">
        <div class="photo-inner">
          <div class="photo-placeholder">
            <span class="photo-icon">✦</span>
            <p>Foto 4</p>
          </div>
          <div class="photo-shine"></div>
        </div>
      </div>
      <div class="photo-card" style="--hue: 240deg">
        <div class="photo-inner">
          <div class="photo-placeholder">
            <span class="photo-icon">✦</span>
            <p>Foto 5</p>
          </div>
          <div class="photo-shine"></div>
        </div>
      </div>
    </div>
    <p class="gallery-hint">Pasa el cursor por las fotos para hacerlas flotar ✦</p>
  </section>

  <!-- ===== MÚSICA ===== -->
  <section class="section music-section">
    <h2 class="section-title">La canción de esta noche</h2>
    <div class="music-player">
      <div class="vinyl" id="vinyl">
        <div class="vinyl-inner">
          <span>DUKI</span>
        </div>
      </div>
      <div class="player-info">
        <p class="track-title">Cine</p>
        <p class="track-artist">Duki</p>
        <div class="player-controls">
          <button class="play-btn" id="playBtn" aria-label="Reproducir/Pausar">
            <span id="playIcon">▶</span>
          </button>
          <div class="progress-bar-wrap">
            <div class="progress-bar" id="progressBar"></div>
          </div>
        </div>
        <p class="audio-status" id="audioStatus">Cargando...</p>
      </div>
    </div>
    <div class="audio-url-wrap" id="audioUrlWrap" style="display:none">
      <p class="audio-url-label">Pegá la URL directa del MP3 (o dejá el archivo en <code>public/cine.mp3</code>):</p>
      <div class="audio-url-row">
        <input type="url" id="audioUrlInput" placeholder="https://ejemplo.com/cine.mp3" />
        <button class="btn-arcane btn-sm" id="audioUrlBtn">Cargar</button>
      </div>
    </div>
    <audio id="bgAudio" loop preload="auto">
      <source src="/cine.mp3" type="audio/mpeg" />
    </audio>
  </section>

  <!-- ===== TRIVIA ===== -->
  <section class="section trivia-section">
    <h2 class="section-title">¿Qué tanto la conocés?</h2>
    <p class="section-sub">¡A ver qué tanto conocés a la cumpleañera!</p>
    <div class="trivia-container" id="triviaContainer"></div>
    <div class="trivia-result" id="triviaResult" style="display:none">
      <p class="result-score" id="resultScore"></p>
      <p class="result-msg" id="resultMsg"></p>
      <button class="btn-arcane" id="retryBtn">Intentar de nuevo</button>
    </div>
  </section>

  <!-- ===== MURO DE CANCIONES ===== -->
  <section class="section wall-section">
    <h2 class="section-title">Muro de Canciones</h2>
    <p class="section-sub">¿Qué canción NO puede faltar en la fiesta? ¡Dejanos saberlo!</p>
    <div class="wall-layout">
      <form class="song-form" id="songForm">
        <div class="form-field">
          <label for="guestName">Tu nombre</label>
          <input type="text" id="guestName" placeholder="¿Cómo te llamás?" maxlength="40" required />
        </div>
        <div class="form-field">
          <label for="songSuggestion">Canción que NO puede faltar</label>
          <input type="text" id="songSuggestion" placeholder="Artista – Canción" maxlength="80" required />
        </div>
        <button type="submit" class="btn-arcane submit-btn">
          <span class="btn-text">Agregar al muro</span>
          <span class="btn-glow"></span>
        </button>
      </form>
      <div class="songs-wall" id="songsWall"></div>
    </div>
  </section>

  <!-- ===== FOOTER ===== -->
  <footer class="footer">
    <div class="footer-runes">✦ ✧ ✦ ✧ ✦</div>
    <p>Con amor para Fio · 16 de Mayo 2026</p>
    <div class="footer-runes">✦ ✧ ✦ ✧ ✦</div>
  </footer>

  <script>
    // ─── PARTÍCULAS ───────────────────────────────────────────────
    const particleContainer = document.getElementById('particles');
    for (let i = 0; i < 60; i++) {
      const p = document.createElement('div');
      p.className = 'particle';
      p.style.cssText = `left:${Math.random()*100}%;top:${Math.random()*100}%;width:${Math.random()*3+1}px;height:${Math.random()*3+1}px;animation-delay:${Math.random()*8}s;animation-duration:${Math.random()*10+6}s;--tx:${(Math.random()-0.5)*200}px;--ty:${(Math.random()-0.5)*200}px;`;
      particleContainer.appendChild(p);
    }

    // ─── CUENTA REGRESIVA ─────────────────────────────────────────
    function updateCountdown() {
      const target = new Date('2026-05-16T20:00:00');
      const now = new Date();
      const diff = target.getTime() - now.getTime();
      if (diff <= 0) {
        ['days','hours','minutes','seconds'].forEach(id => {
          document.getElementById(id).textContent = '00';
        });
        return;
      }
      const d = Math.floor(diff / 86400000);
      const h = Math.floor((diff % 86400000) / 3600000);
      const m = Math.floor((diff % 3600000) / 60000);
      const s = Math.floor((diff % 60000) / 1000);
      document.getElementById('days').textContent    = String(d).padStart(2,'0');
      document.getElementById('hours').textContent   = String(h).padStart(2,'0');
      document.getElementById('minutes').textContent = String(m).padStart(2,'0');
      document.getElementById('seconds').textContent = String(s).padStart(2,'0');
    }
    updateCountdown();
    setInterval(updateCountdown, 1000);

    // ─── MÚSICA ───────────────────────────────────────────────────
    const audio       = document.getElementById('bgAudio') as HTMLAudioElement;
    const playBtn     = document.getElementById('playBtn')!;
    const playIcon    = document.getElementById('playIcon')!;
    const progressBar = document.getElementById('progressBar')!;
    const vinyl       = document.getElementById('vinyl')!;
    const audioStatus = document.getElementById('audioStatus')!;
    const audioUrlWrap = document.getElementById('audioUrlWrap')!;
    const audioUrlInput = document.getElementById('audioUrlInput') as HTMLInputElement;
    const audioUrlBtn  = document.getElementById('audioUrlBtn')!;
    let playing = false;
    let audioReady = false;

    function setStatus(msg: string, type: 'ok'|'err'|'loading' = 'loading') {
      audioStatus.textContent = msg;
      audioStatus.className = 'audio-status ' + type;
    }

    function startPlaying() {
      audio.play().then(() => {
        playing = true;
        audioReady = true;
        playIcon.textContent = '⏸';
        vinyl.style.animationPlayState = 'running';
        setStatus('Reproduciendo ♪', 'ok');
      }).catch((err) => {
        setStatus('No se pudo reproducir. Revisá que el archivo exista.', 'err');
        audioUrlWrap.style.display = 'block';
      });
    }

    function stopPlaying() {
      audio.pause();
      playing = false;
      playIcon.textContent = '▶';
      vinyl.style.animationPlayState = 'paused';
      setStatus('Pausado', 'loading');
    }

    playBtn.addEventListener('click', () => {
      if (playing) stopPlaying();
      else startPlaying();
    });

    audio.addEventListener('canplaythrough', () => {
      audioReady = true;
      if (!playing) setStatus('Listo para reproducir ▶', 'ok');
    });

    audio.addEventListener('timeupdate', () => {
      if (audio.duration) {
        progressBar.style.width = (audio.currentTime / audio.duration * 100) + '%';
      }
    });

    audio.addEventListener('error', () => {
      setStatus('Archivo no encontrado. Usá el campo de abajo para cargar la canción.', 'err');
      audioUrlWrap.style.display = 'block';
    });

    audioUrlBtn.addEventListener('click', () => {
      const url = audioUrlInput.value.trim();
      if (!url) return;
      audio.src = url;
      audio.load();
      setStatus('Cargando URL...', 'loading');
      audio.addEventListener('canplaythrough', () => startPlaying(), { once: true });
      audio.addEventListener('error', () => setStatus('No se pudo cargar esa URL.', 'err'), { once: true });
    });

    // Primer click en la página dispara reproducción
    document.addEventListener('click', function onFirstClick() {
      if (!playing && audioReady) startPlaying();
    }, { once: true });

    // ─── TRIVIA ───────────────────────────────────────────────────
    const questions: { q: string; opts: string[]; correct: number }[] = [
      { q: '¿Cuál es la comida favorita de Fio?',            opts: ['Sushi','Pizza','Pasta','Tacos'],                    correct: 1 },
      { q: '¿A qué lugar del mundo le encantaría viajar?',   opts: ['París','Tokio','Nueva York','Cancún'],              correct: 1 },
      { q: '¿Cuál es su serie favorita?',                    opts: ['Stranger Things','Squid Game','Euphoria','Arcane'], correct: 3 },
      { q: '¿Qué artista escucha todos los días?',           opts: ['Bad Bunny','Duki','Bizarrap','Peso Pluma'],         correct: 1 },
      { q: '¿Cuál es su color favorito?',                    opts: ['Rojo','Verde','Violeta','Amarillo'],                correct: 2 },
    ];

    let triviaScore = 0;
    let triviaIndex = 0;

    function renderQuestion() {
      const c = document.getElementById('triviaContainer')!;
      const q = questions[triviaIndex];
      c.innerHTML = `
        <div class="trivia-card">
          <div class="trivia-progress">
            <div class="trivia-progress-fill" style="width:${(triviaIndex/questions.length)*100}%"></div>
          </div>
          <p class="trivia-num">Pregunta ${triviaIndex+1} / ${questions.length}</p>
          <p class="trivia-q">${q.q}</p>
          <div class="trivia-opts">
            ${q.opts.map((o,i) => `<button class="trivia-opt" data-idx="${i}">${o}</button>`).join('')}
          </div>
        </div>
      `;
      c.querySelectorAll('.trivia-opt').forEach(btn => {
        btn.addEventListener('click', function(this: HTMLButtonElement) {
          const chosen = parseInt(this.dataset.idx!);
          c.querySelectorAll<HTMLButtonElement>('.trivia-opt').forEach(b => b.disabled = true);
          if (chosen === q.correct) {
            this.classList.add('correct');
            triviaScore++;
          } else {
            this.classList.add('wrong');
            (c.querySelectorAll('.trivia-opt')[q.correct] as HTMLElement).classList.add('correct');
          }
          setTimeout(() => {
            triviaIndex++;
            if (triviaIndex < questions.length) renderQuestion();
            else showResult();
          }, 900);
        });
      });
    }

    function showResult() {
      document.getElementById('triviaContainer')!.style.display = 'none';
      const res = document.getElementById('triviaResult')!;
      res.style.display = 'flex';
      document.getElementById('resultScore')!.textContent = `${triviaScore} / ${questions.length}`;
      const msgs = [
        'Mmm... parece que hay que conocerla un poco más. ¡Vení a la fiesta!',
        'Bien, algo sabés. Pero aún hay secretos por descubrir.',
        '¡No está mal! Sos parte de su mundo.',
        'Genial, la conocés muy bien. ¡Sos del círculo de oro!',
        '¡PERFECTO! Definitivamente sos su persona favorita. ✦',
      ];
      document.getElementById('resultMsg')!.textContent = msgs[Math.min(Math.floor(triviaScore/questions.length*4),4)];
    }

    document.getElementById('retryBtn')!.addEventListener('click', () => {
      triviaScore = 0;
      triviaIndex = 0;
      const c = document.getElementById('triviaContainer')!;
      c.style.display = 'block';
      document.getElementById('triviaResult')!.style.display = 'none';
      renderQuestion();
    });

    renderQuestion();

    // ─── MURO DE CANCIONES ────────────────────────────────────────
    interface SongEntry { name: string; song: string; date: string }
    const songs: SongEntry[] = JSON.parse(localStorage.getItem('fio15_songs') || '[]');

    function escapeHTML(str: string) {
      return str.replace(/[&<>"']/g, (c: string) => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c] ?? c));
    }

    function renderSongs() {
      const wall = document.getElementById('songsWall')!;
      if (songs.length === 0) {
        wall.innerHTML = '<p class="wall-empty">¡Sé el primero en sugerir una canción!</p>';
        return;
      }
      wall.innerHTML = songs.map((s, i) => `
        <div class="song-card" style="--i:${i}">
          <span class="song-note">♪</span>
          <p class="song-title">${escapeHTML(s.song)}</p>
          <p class="song-guest">— ${escapeHTML(s.name)}</p>
        </div>
      `).join('');
    }

    renderSongs();

    document.getElementById('songForm')!.addEventListener('submit', (e) => {
      e.preventDefault();
      const nameEl = document.getElementById('guestName') as HTMLInputElement;
      const songEl = document.getElementById('songSuggestion') as HTMLInputElement;
      const name = nameEl.value.trim();
      const song = songEl.value.trim();
      if (!name || !song) return;
      songs.unshift({ name, song, date: new Date().toLocaleDateString('es-AR') });
      localStorage.setItem('fio15_songs', JSON.stringify(songs));
      renderSongs();
      (e.target as HTMLFormElement).reset();
      const btn = document.querySelector('.submit-btn') as HTMLButtonElement;
      btn.textContent = '¡Agregada! ✦';
      btn.classList.add('success');
      setTimeout(() => {
        btn.innerHTML = '<span class="btn-text">Agregar al muro</span><span class="btn-glow"></span>';
        btn.classList.remove('success');
      }, 1800);
    });
  </script>
</body>
</html>
